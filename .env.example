# ── Shopify (optional — seed catalog used when unset) ─────────────────────────
SHOPIFY_STORE_DOMAIN=thekohawkshop.com

# ── Service URLs (set automatically in docker-compose; override for custom infra)
CATALOG_SERVICE_URL=http://localhost:8001
PAYMENT_SERVICE_URL=http://localhost:8002
ORDER_SERVICE_URL=http://localhost:8003

# ── Data stores ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://commerce:commerce@localhost:5432/commerce
REDIS_URL=redis://localhost:6379/0
CATALOG_CACHE_TTL_SECONDS=3600

# ── AWS / SQS (optional — order events published when set) ─────────────────────
AWS_REGION=us-east-1
SQS_ORDER_EVENTS_URL=https://sqs.us-east-1.amazonaws.com/123456789/order-events.fifo

# ── Kestra workflows (optional) ───────────────────────────────────────────────
KESTRA_URL=http://localhost:8080
KESTRA_NAMESPACE=demo.commerce
KESTRA_FLOW_ID=chat-commerce-order-fulfillment
KESTRA_RADAR_FLOW_ID=campus-demand-radar

# ── storefront-ui Vite (set when running UI dev server separately) ─────────────
VITE_API_GATEWAY_URL=http://localhost:8000
