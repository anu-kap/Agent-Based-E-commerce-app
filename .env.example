PORT=3000

# Optional. When set, the agent calls Shopify Storefront MCP for live
# catalog + cart instead of the seed catalog at data/seed_catalog.json.
SHOPIFY_STORE_DOMAIN=thekohawkshop.com

# Optional. When set, the app uses Postgres as a 1-hour read-through
# cache for Shopify search responses, persists chat sessions and
# intents (so the radar reads real history across restarts), and
# stores local demo orders. With this unset, all DB ops silently
# no-op and the app keeps working from the seed catalog.
DATABASE_URL=postgresql://commerce:commerce@localhost:5432/commerce

# Optional. Override the default 1-hour cache TTL.
# CATALOG_CACHE_TTL_SECONDS=3600

# Optional. Kestra workflow execution endpoints.
KESTRA_URL=http://localhost:8080
KESTRA_NAMESPACE=demo.commerce
KESTRA_FLOW_ID=chat-commerce-order-fulfillment
KESTRA_RADAR_FLOW_ID=campus-demand-radar
